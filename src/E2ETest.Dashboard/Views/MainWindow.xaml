<Window x:Class="E2ETest.Dashboard.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="E2E Test Dashboard" Height="760" Width="1280"
        Background="#1E1E1E" Foreground="#EEE" FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1177BB"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#444"/>
                    <Setter Property="Foreground" Value="#888"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#252526" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="🧪 " FontSize="18" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TestName}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0,24,0"/>
                    <TextBlock Text="{Binding ProgressText}" FontSize="13" VerticalAlignment="Center" Foreground="#9CDCFE"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="13" VerticalAlignment="Center" Foreground="{Binding StatusColor}" Margin="24,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="1">
                    <Button Content="🔄 Re-run" Style="{StaticResource ActionButton}" Click="OnRerunClick" IsEnabled="{Binding CanRerun}" Margin="0,0,8,0"/>
                    <Button Content="📁 Open folder" Style="{StaticResource ActionButton}" Click="OnOpenFolderClick" IsEnabled="{Binding HasRunResult}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="#252526" BorderBrush="#333" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Steps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="Row" Padding="10,8" BorderBrush="#333" BorderThickness="0,0,0,1"
                                    Background="{Binding RowBackground}" Cursor="Hand" MouseLeftButtonDown="OnStepClick" Tag="{Binding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Top" Margin="0,2,10,0" Foreground="{Binding ColorBrush}"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Description}" FontSize="13" Foreground="{Binding ColorBrush}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding TechnicalLabel}" FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding DurationLabel}" FontSize="10" Foreground="#666" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="#000" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding PreviewCaption}" Foreground="#9CDCFE" FontSize="12" Padding="4,2,4,6"/>
                <Image Grid.Row="1" Source="{Binding ScreenshotImage}" Stretch="Uniform"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,1,0,0">
            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Logs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Foreground="#CCC" Padding="10,1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
